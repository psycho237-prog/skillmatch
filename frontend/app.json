{
  "expo": {
    "name": "Swapster",
    "slug": "skillmatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swapster",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/images/icon.png",
        "backgroundColor": "#0F0F23"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swapster.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Swapster needs camera access to take photos for your service listings.",
        "NSPhotoLibraryUsageDescription": "Swapster needs photo library access to upload images for your service listings.",
        "NSLocationWhenInUseUsageDescription": "Swapster needs your location to show nearby services.",
        "NSLocationAlwaysUsageDescription": "Swapster uses your location to recommend nearby services."
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "versionCode": 1,
      "package": "com.swapster.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Swapster to access your camera for service photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Swapster to access your photos for service listings."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Swapster to use your location to find nearby services."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0061FF"
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "945a8eb7-010e-4cd6-bf4b-f8539b274bb6"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/945a8eb7-010e-4cd6-bf4b-f8539b274bb6"
    }
  }
}
