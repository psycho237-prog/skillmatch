{
  "expo": {
    "name": "SkillMatch",
    "slug": "skillmatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "skillmatch",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/images/splash.png",
        "backgroundColor": "#0F0F23"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skillmatch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SkillMatch needs camera access to take photos for your service listings.",
        "NSPhotoLibraryUsageDescription": "SkillMatch needs photo library access to upload images for your service listings.",
        "NSLocationWhenInUseUsageDescription": "SkillMatch needs your location to show nearby services.",
        "NSLocationAlwaysUsageDescription": "SkillMatch uses your location to recommend nearby services."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.skillmatch.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SkillMatch to access your camera for service photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SkillMatch to access your photos for service listings."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SkillMatch to use your location to find nearby services."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0061FF"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "945a8eb7-010e-4cd6-bf4b-f8539b274bb6"
      }
    }
  }
}
